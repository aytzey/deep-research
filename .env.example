OPENALEX_EMAIL=you@example.com
UNPAYWALL_EMAIL=you@example.com
SEMANTIC_SCHOLAR_API_KEY=

# Local Zotero (recommended - install zotero-mcp-server separately for full library management)
ZOTERO_LOCAL=true
ZOTERO_LIBRARY_TYPE=user

# Web Zotero API (alternative to local)
ZOTERO_LIBRARY_ID=
ZOTERO_API_KEY=

# Sci-Hub (disabled by default)
SCIHUB_ENABLED=false
SCIHUB_MIRRORS=https://sci-hub.se,https://sci-hub.st,https://sci-hub.ru
SCIHUB_TIMEOUT_SEC=30

# LibGen
LIBGEN_MIRRORS=https://libgen.is,https://libgen.rs,https://libgen.li
LIBGEN_TIMEOUT_SEC=20

# Storage
PAPER_PILOT_DATA_DIR=./data
CACHE_TTL_SEC=86400

# Institutional networks (optional)
SSL_CERT_FILE=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
